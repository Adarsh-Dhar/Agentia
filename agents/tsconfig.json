{
  "compilerOptions": {
    "module": "node16",
    "target": "es2022",
    "lib": ["es2022", "dom", "webworker"],
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}